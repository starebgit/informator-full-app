    "guidelines": {
        "b&f_guidelines": "Smernice vodenja Blanc&Fischer",
        "act_as_role_models": "Delujemo kot vzorniki.",
        "take_responsibility_and_set_goals": "Sami prevzevamo odgovornost in postavljamo jasne cilje.",
        "environment_of_trust": "Ustvarjamo okolje zaupanja in usposobljenosti.",
        "constructive_feedback": "Dajemo konstruktivne povratne informacije za podporo razvoja ljudi.",
        "drive_change": "Poganjamo spremembe.",
        "learn_from_mistakes": "Iz napak se učimo.",
        "support_diversity_and_integration": "Podpiramo raznolikost in integracijo.",
        "think_and_act_holistic": "Razmišljamo in delujemo celostno.",
        "act_as_role_models_desc": "Za uspeh našega podjetja je vodenje naših vodilnih uslužbencev bistvenega pomena - kot vodilni uslužbenci moramo biti vzor. Naše sodelavke in sodelavci se ravnajo po naših vodilnih uslužbencih, ne glede na to, ali namerno ali ne. Verodostojnost je pri tem ključnega pomena: živimo to, kar govorimo in mislimo. Zato je načelo vodenja tudi osnova vseh dejanj vodilnih uslužbencev in odločilnega pomena z učinkovanje vodstva.",
        "take_responsibility_and_set_goals_desc": "V svetu, ki ga zaznamujejo hitre spremembe in vedno manjša predvidljivost, je treba znotraj podjetja prevzeti odgovornost ter sprejemati odločitve na vseh ravneh. Pri tem smo v ospredju.",
        "environment_of_trust_desc": "Da bi zmanjšali kompleksnost svojega delovnega okolja in s tem pridobili konkurenčno moč, se zavzemamo za pravilno predajo odgovornosti in zaupamo prednostim svojih zaposlenih. Hkrati smo za svoje sodelavke in sodelavce zanesljivi ter predvidljivi.",
        "constructive_feedback_desc": "Kot organizacija, ki se uči, stavimo na prednosti svojih sodelavk in sodelavcev ter izkoristimo vse priložnosti za izboljšave. To lahko dosežemo z rednimi in pravočasnimi povratnimi informacijami na individualni ter organizacijski ravni. Spodbujamo pozitivno kulturo povratnih informacij, ki jo zaznamujeta odprtost in vzajemno zaupanje.",
        "drive_change_desc": "V nestanovitnem okolju so odpronost do sprememb, okretnost in aktivno oblikovanje trajnostih sprememb na vseh ravneh zagotovila za naše preživetje. Naše podjetje ravno zato ostaja uspešno.",
        "learn_from_mistakes_desc": "Hitrost kot konkurenčna prednost. Za uspeh našega podjetja je odločilnega pomena, da razvijamo inovativne ideje v vedno krajših ciklih in se učimo iz morebitnih povratnih udarcev. Ravnanje z napaki in posledična spoznanja so osrednji dejavnik za prihodnost našega podjetja.",
        "support_diversity_and_integration_desc": "Prepričani smo, da smo zaradi raznolikosti boljši in bolj trpežni. Različni vidiki in kritični dialog na spoštljivi ravni vodijo do trpežnejših rešitev ter povečajo našo inovativno moč.",
        "think_and_act_holistic_desc": "Postavitev kot mednarodna skupina podjetji je odločilna konkurenčna prednost. Da bi izkoristili to prednost, moramo razmišljati preko meja lastnega področja, globalno sodelovati in integrirati nove razvoje ter trende."
    },
